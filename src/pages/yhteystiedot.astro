---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Huoneistoremontit Turku, Kaarina ja Varsinais-Suomi"
  description="Huoneistoremontit Turku, Kaarinan ja koko Varsinais-Suomi. Toteutamme huoneistoremontit ammattitaidolla, olipa kyseessä pintaremontti tai koko huoneiston laajempi uudistus."
  hasHero={true}
>

  <!-- Hero desktop -->
  <section
    class="relative h-[75svh] -mb-px bg-musta bg-cover bg-center bg-no-repeat hidden lg:flex flex-col justify-center items-center"
    style="background-image: linear-gradient(rgba(43,43,43,0.7), rgba(43,43,43,0.7)), url('/images/uploads/yhteystiedot-hero.webp')"
  >
    <!-- Content -->
    <div class="relative w-full max-w-8xl mx-auto px-80 flex justify-start items-end">
      <div class="w-[603px] flex flex-col gap-s-6-d">

        <!-- Texts -->
        <div class="flex flex-col gap-s-3-d border-l-2 border-valkoinen pl-s-10-d py-s-3-d">
          <!-- Tagline + line -->
          <div class="flex flex-col gap-s-1-d">
            <div class="inline-flex items-center gap-1.5">
              <span class="text-valkoinen text-body-large  leading-7">Ota yhteyttä</span>
              <div class="w-16 h-px bg-valkoinen"></div>
            </div>
            <h1 class="text-valkoinen text-h1-d">Yhteystiedot</h1>
          </div>
          <!-- Description -->
          <p class="w-[537px] text-valkoinen text-body-large  leading-7">
            Suunnitteletko remonttia tai uudisrakentamista? Ota yhteyttä, niin käydään projektisi läpi ja laaditaan selkeä tarjous.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Hero mobiili -->
  <section
    class="relative h-[70svh] -mb-px bg-musta bg-cover bg-center bg-no-repeat flex lg:hidden flex-col justify-center items-center"
    style="background-image: linear-gradient(rgba(43,43,43,0.7), rgba(43,43,43,0.7)), url('/images/uploads/yhteystiedot-hero.webp')"
  >
    <!-- Content -->
    <div class="relative w-full px-4 flex justify-start items-end">
      <div class="flex-1 flex flex-col gap-s-7-m">

        <!-- Texts -->
        <div class="flex flex-col gap-s-5-m border-l-2 border-valkoinen pl-s-4-m py-s-3-m">
          <!-- Tagline + line -->
          <div class="flex flex-col gap-s-1-m">
            <div class="inline-flex items-center gap-1.5">
              <span class="text-valkoinen text-xl leading-5">Ota yhteyttä</span>
              <div class="w-7 h-px bg-valkoinen"></div>
            </div>
            <h1 class="text-valkoinen text-h1-m">Yhteystiedot</h1>
          </div>
          <!-- Description -->
          <p class="text-valkoinen text-lg leading-5">
            Suunnitteletko remonttia tai uudisrakentamista? Ota yhteyttä, niin käydään projektisi läpi ja laaditaan selkeä tarjous.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Yhteydenotto -->
  <section class="bg-valkoinen">
    <div class="max-w-8xl mx-auto px-s-4-m xl:px-16 py-s-10-d">

      <!-- Desktop layout -->
      <div class="hidden lg:flex gap-s-3-d items-start">

        <h2 class="w-96 shrink-0 text-musta text-h2-d">Yhteydenotto</h2>

        <form
          name="yhteydenotto"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="flex-1 flex flex-col gap-s-4-d"
        >
          <input type="hidden" name="form-name" value="yhteydenotto" />
          <p class="hidden">
            <label>Älä täytä: <input name="bot-field" /></label>
          </p>

          <!-- Etunimi + Sukunimi -->
          <div class="flex gap-s-3-d">
            <div class="flex-1 flex flex-col gap-2">
              <label for="etunimi" class="text-black text-body-normal font-normal">Etunimi*</label>
              <input
                id="etunimi"
                name="etunimi"
                type="text"
                required
                class="w-full h-12 border border-musta rounded px-3 text-black text-body-normal bg-transparent focus:outline-none focus:ring-2 focus:ring-oranssi"
              />
            </div>
            <div class="flex-1 flex flex-col gap-2">
              <label for="sukunimi" class="text-black text-body-normal font-normal">Sukunimi*</label>
              <input
                id="sukunimi"
                name="sukunimi"
                type="text"
                required
                class="w-full h-12 border border-musta rounded px-3 text-black text-body-normal bg-transparent focus:outline-none focus:ring-2 focus:ring-oranssi"
              />
            </div>
          </div>

          <!-- Sähköposti + Puhelinnumero -->
          <div class="flex gap-s-3-d">
            <div class="flex-1 flex flex-col gap-2">
              <label for="email" class="text-black text-body-normal font-normal">Sähköposti*</label>
              <input
                id="email"
                name="email"
                type="email"
                required
                class="w-full h-12 border border-musta rounded px-3 text-black text-body-normal bg-transparent focus:outline-none focus:ring-2 focus:ring-oranssi"
              />
            </div>
            <div class="flex-1 flex flex-col gap-2">
              <label for="puhelin" class="text-black text-body-normal font-normal">Puhelinnumero</label>
              <input
                id="puhelin"
                name="puhelin"
                type="tel"
                class="w-full h-12 border border-musta rounded px-3 text-black text-body-normal bg-transparent focus:outline-none focus:ring-2 focus:ring-oranssi"
              />
            </div>
          </div>

          <!-- Aihe -->
          <div class="flex flex-col gap-s-2-d">
            <span class="text-black text-body-normal font-normal">Mitä asiasi koskee?</span>
            <div class="flex flex-col gap-s-2-d">
              <div class="flex gap-s-3-d flex-wrap">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="aihe" value="Kylpyhuone ja saunaremontit" class="accent-oranssi w-4 h-4" />
                  <span class="text-black text-body-normal">Kylpyhuone ja saunaremontit</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="aihe" value="Keittiöremontit" class="accent-oranssi w-4 h-4" />
                  <span class="text-black text-body-normal">Keittiöremontit</span>
                </label>
              </div>
              <div class="flex gap-s-3-d flex-wrap">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="aihe" value="Huoneistoremontit" class="accent-oranssi w-4 h-4" />
                  <span class="text-black text-body-normal">Huoneistoremontit</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="aihe" value="Julkisivuremontit" class="accent-oranssi w-4 h-4" />
                  <span class="text-black text-body-normal">Julkisivuremontit</span>
                </label>
              </div>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="aihe" value="Uudisrakentaminen" class="accent-oranssi w-4 h-4" />
                <span class="text-black text-body-normal">Uudisrakentaminen</span>
              </label>
            </div>
          </div>

          <!-- Viesti -->
          <div class="flex flex-col gap-2">
            <label for="viesti" class="text-black text-body-normal font-normal">Viestisi</label>
            <textarea
              id="viesti"
              name="viesti"
              rows="6"
              class="w-full border border-musta rounded px-3 py-3 text-black text-body-normal bg-transparent focus:outline-none focus:ring-2 focus:ring-oranssi resize-none"
            ></textarea>
          </div>

          <!-- Tietosuoja + Lähetä -->
          <div class="flex flex-col gap-s-5-d">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="tietosuoja" required class="accent-oranssi w-3.5 h-3.5 border border-musta rounded" />
              <span class="text-black text-body-normal">Hyväksyn, että tietojani käytetään <a href="/tietosuojaseloste" class="font-semibold hover:text-oranssi" target="_blank">tietosuojaselosteen</a> mukaisesti.</span>
            </label>
            <button
              type="submit"
              class="self-start px-s-3-d py-3 bg-oranssi hover:bg-hover-oranssi shadow-[0px_4px_4px_0px_rgba(0,0,0,0.25)] text-black text-body-medium font-normal transition-colors"
            >
              Lähetä
            </button>
          </div>
        </form>
      </div>

      <!-- Mobile layout -->
      <div class="flex flex-col gap-s-6-m lg:hidden">
        <h2 class="text-musta text-h2-m">Yhteydenotto</h2>

        <form
          name="yhteydenotto"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="flex flex-col gap-s-5-m"
        >
          <input type="hidden" name="form-name" value="yhteydenotto" />
          <p class="hidden">
            <label>Älä täytä: <input name="bot-field" /></label>
          </p>

          <div class="flex flex-col gap-2">
            <label for="etunimi-m" class="text-musta text-body-normal font-normal">Etunimi*</label>
            <input id="etunimi-m" name="etunimi" type="text" required class="w-full h-12 border border-musta rounded px-3 text-musta text-body-normal bg-transparent focus:outline-none focus:ring-2 focus:ring-oranssi" />
          </div>
          <div class="flex flex-col gap-2">
            <label for="sukunimi-m" class="text-musta text-body-normal font-normal">Sukunimi*</label>
            <input id="sukunimi-m" name="sukunimi" type="text" required class="w-full h-12 border border-musta rounded px-3 text-musta text-body-normal bg-transparent focus:outline-none focus:ring-2 focus:ring-oranssi" />
          </div>
          <div class="flex flex-col gap-2">
            <label for="email-m" class="text-musta text-body-normal font-normal">Sähköposti*</label>
            <input id="email-m" name="email" type="email" required class="w-full h-12 border border-musta rounded px-3 text-musta text-body-normal bg-transparent focus:outline-none focus:ring-2 focus:ring-oranssi" />
          </div>
          <div class="flex flex-col gap-2">
            <label for="puhelin-m" class="text-musta text-body-normal font-normal">Puhelinnumero</label>
            <input id="puhelin-m" name="puhelin" type="tel" class="w-full h-12 border border-musta rounded px-3 text-musta text-body-normal bg-transparent focus:outline-none focus:ring-2 focus:ring-oranssi" />
          </div>

          <div class="flex flex-col gap-s-2-m">
            <span class="text-musta text-body-normal font-normal">Mitä asiasi koskee?</span>
            <div class="flex flex-col gap-3">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="aihe" value="Kylpyhuone ja saunaremontit" class="accent-oranssi w-4 h-4" />
                <span class="text-musta text-body-normal">Kylpyhuone ja saunaremontit</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="aihe" value="Keittiöremontit" class="accent-oranssi w-4 h-4" />
                <span class="text-musta text-body-normal">Keittiöremontit</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="aihe" value="Huoneistoremontit" class="accent-oranssi w-4 h-4" />
                <span class="text-musta text-body-normal">Huoneistoremontit</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="aihe" value="Julkisivuremontit" class="accent-oranssi w-4 h-4" />
                <span class="text-musta text-body-normal">Julkisivuremontit</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="aihe" value="Uudisrakentaminen" class="accent-oranssi w-4 h-4" />
                <span class="text-musta text-body-normal">Uudisrakentaminen</span>
              </label>
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <label for="viesti-m" class="text-musta text-body-normal font-normal">Viestisi</label>
            <textarea id="viesti-m" name="viesti" rows="6" class="w-full border border-musta rounded px-3 py-3 text-musta text-body-normal bg-transparent focus:outline-none focus:ring-2 focus:ring-oranssi resize-none"></textarea>
          </div>

          <div class="flex flex-col gap-s-5-m">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="tietosuoja" required class="accent-oranssi w-3.5 h-3.5 border border-musta rounded" />
              <span class="text-musta text-body-small">Hyväksyn, että tietojani käytetään tietosuojaselosteen mukaisesti.</span>
            </label>
            <button type="submit" class="self-start px-s-3-d py-3 bg-oranssi hover:bg-hover-oranssi shadow-[0px_4px_4px_0px_rgba(0,0,0,0.25)] text-musta text-body-medium font-normal transition-colors">
              Lähetä
            </button>
          </div>
        </form>
      </div>

    </div>
  </section>

  <!-- Henkilöstö -->
  <section class="bg-valkoinen ">
    <div class="max-w-8xl mx-auto px-s-4-m xl:px-16 pt-s-10-d">
      <div class="flex flex-col lg:flex-row gap-s-3-d items-start">

        <h2 class="w-full lg:w-96 shrink-0 text-musta lg:text-h2-d text-h2-m">Henkilöstö</h2>

        <div class="flex flex-col sm:flex-row gap-s-4-d lg:gap-48">
          <div class="flex flex-col gap-s-1-d">
            <p class="text-musta text-h3-d font-light">Jussi Salminen</p>
            <a href="tel:+358405457031" class="text-musta text-body-normal hover:text-oranssi transition-colors">
              puh. 040-5457031
            </a>
          </div>
          <div class="flex flex-col gap-s-1-d">
            <p class="text-musta text-h3-d font-light">Tuomas Lehtiö</p>
            <a href="tel:+358407572546" class="text-musta text-body-normal hover:text-oranssi transition-colors">
              puh. 040-7572546
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Yritys + Kartta -->
  <section class="bg-valkoinen">
    <div class="max-w-8xl mx-auto px-s-4-m xl:px-16 py-s-10-d">
      <div class="flex flex-col lg:flex-row gap-s-6-d items-start">

        <!-- Yhtiön tiedot -->
        <div class="flex flex-col gap-s-3-d">
          <h2 class="text-musta lg:text-h3-d text-h3-m font-light">J&amp;T Rakennuspalvelu Oy</h2>
          <address class="not-italic text-musta text-body-normal leading-6">
            Mäntysaarenkuja 21<br />
            21330 Paattinen
          </address>
        </div>

        <!-- Google Maps -->
        <div class="w-full lg:flex-1 h-80 lg:h-96 rounded-sm overflow-hidden">
          <iframe
            title="J&T Rakennuspalvelu Oy sijainti"
            src="https://maps.google.com/maps?q=Mäntysaarenkuja+21,21330+Paattinen,Finland&output=embed&hl=fi"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>

      </div>
    </div>
  </section>

</Layout>

<script>
  document.querySelectorAll('input[type="radio"][name="aihe"]').forEach((radio) => {
    radio.addEventListener("click", function (this: HTMLInputElement) {
      if (this.dataset.checked === "true") {
        this.checked = false;
        this.dataset.checked = "false";
      } else {
        document
          .querySelectorAll('input[type="radio"][name="aihe"]')
          .forEach((r) => ((r as HTMLInputElement).dataset.checked = "false"));
        this.dataset.checked = "true";
      }
    });
  });
</script>