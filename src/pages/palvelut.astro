---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Etusivu"
  description="J&T Rakennuspalvelu Oy on Turussa toimiva rakennuspalvelu"
  hasHero={true}
  heroImage="/images/uploads/hero-tausta.webp"
>

  <!-- Hero desktop -->
  <section
    class="relative h-[75svh] -mb-px bg-musta bg-cover bg-center bg-no-repeat hidden lg:flex flex-col justify-center items-center"
    style="background-image: linear-gradient(rgba(43,43,43,0.7), rgba(43,43,43,0.7)), url('/images/uploads/palvelut-hero.webp')"
  >
    <!-- Content -->
    <div class="relative w-full max-w-8xl mx-auto px-80 flex justify-start items-end">
      <div class="w-[603px] flex flex-col gap-s-6-d">

        <!-- Texts -->
        <div class="flex flex-col gap-s-3-d border-l-2 border-valkoinen pl-s-10-d py-s-3-d">
          <!-- Tagline + line -->
          <div class="flex flex-col gap-s-1-d">
            <div class="inline-flex items-center gap-1.5">
              <span class="text-valkoinen text-body-large  leading-7">Rakentaminen, joka kannattaa</span>
              <div class="w-16 h-px bg-valkoinen"></div>
            </div>
            <h1 class="text-valkoinen text-h1-d">Palvelut</h1>
          </div>
          <!-- Description -->
          <p class="w-[537px] text-valkoinen text-body-large  leading-7">
            Tarjoamme kattavat rakennus- ja remonttipalvelut, joissa yhdistyvät laatu, luotettavuus ja sujuva projektinhallinta. 
            Huolehdimme toteutuksesta alusta loppuun – asiakkaan tarpeet edellä.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Hero mobiili -->
  <section
    class="relative h-[70svh] -mb-px bg-musta bg-cover bg-center bg-no-repeat flex lg:hidden flex-col justify-center items-center"
    style="background-image: linear-gradient(rgba(43,43,43,0.7), rgba(43,43,43,0.7)), url('/images/uploads/palvelut-hero-mobiili.webp')"
  >
    <!-- Content -->
    <div class="relative w-full px-4 flex justify-start items-end">
      <div class="flex-1 flex flex-col gap-s-7-m">

        <!-- Texts -->
        <div class="flex flex-col gap-s-5-m border-l-2 border-valkoinen pl-s-4-m py-s-3-m">
          <!-- Tagline + line -->
          <div class="flex flex-col gap-s-1-m">
            <div class="inline-flex items-center gap-1.5">
              <span class="text-valkoinen text-xl  leading-5">Rakentaminen, joka kannattaa</span>
              <div class="w-7 h-px bg-valkoinen"></div>
            </div>
            <h1 class="text-valkoinen text-h1-m ">Palvelut</h1>
          </div>
          <!-- Description -->
          <p class="text-valkoinen text-lg leading-5">
            Tarjoamme kattavat rakennus- ja remonttipalvelut, joissa yhdistyvät laatu, luotettavuus ja sujuva projektinhallinta. 
            Huolehdimme toteutuksesta alusta loppuun – asiakkaan tarpeet edellä.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Palvelut section -->
  <section class="bg-harmaa">

    <!-- Desktop -->
    <div class="hidden lg:flex flex-col items-center gap-s-4-d px-16 py-s-10-d max-w-8xl mx-auto">

      <!-- Rivi 1: Header + Huoneistoremontti -->
      <div class="flex items-center gap-s-3-d">

        <!-- Header -->
        <div class="w-[532px] flex flex-col gap-s-5-d">
          <div class="flex flex-col gap-s-3-d">
            <div class="inline-flex items-center gap-1.5">
              <span class="text-musta text-body-large leading-7">Palvelut</span>
              <div class="w-16 h-px bg-musta"></div>
            </div>
            <h2 class="text-musta text-h2-d ">Remonttipalvelut moneen tarpeeseen</h2>
            <p class="text-musta text-body-normal  leading-6">
              Meiltä saat laajat remonttipalvelut, jotka kattavat kaiken kodin ja kiinteistöjen kunnostamisesta uudisrakentamiseen.
            </p>
          </div>
          <a href="/palvelut" class="self-start px-s-3-d py-3 bg-oranssi hover:bg-hover-oranssi shadow-[0px_4px_4px_0px_rgba(0,0,0,0.25)] flex justify-center items-center text-black text-body-medium font-normal">
            Kaikki palvelut
          </a>
        </div>

        <!-- Huoneistoremontti -->
        <a href="/palvelut/huoneistoremontit" class="group relative w-[532px] h-[709px] overflow-hidden">
          <img src="/images/uploads/huoneistoremontti.webp" alt="Huoneistoremontti" class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-musta opacity-0 group-hover:opacity-50 transition-opacity duration-100"></div>
          <img src="/images/uploads/oikea-nuoli.svg" alt="" class="absolute top-s-3-d right-s-3-d w-6 h-6 z-10 group-hover:hidden" />
          <img src="/images/uploads/oikea-nuoli-oranssi.svg" alt="" class="absolute top-s-3-d right-s-3-d w-6 h-6 z-10 hidden group-hover:block" />
          <div class="absolute bottom-0 left-0 right-0 px-s-4-d pt-s-10-d pb-s-4-d bg-gradient-to-t from-musta via-musta/60 to-transparent">
            <h3 class="text-valkoinen text-h4-d ">Huoneistoremontti</h3>
            <p class="text-valkoinen text-body-small  leading-5 mt-s-1-d">Tarjoamme remonttipalvelut pienistä pintätöistä laajoihin kokonaisuuksiin – aina huolellisesti suunniteltuna toteutukseen.</p>
          </div>
        </a>

      </div>

      <!-- Rivi 2: Keittiöremontti + Sauna -->
      <div class="flex items-start gap-s-3-d">

        <a href="/palvelut/keittioremontit" class="group relative w-[532px] h-[709px] overflow-hidden">
          <img src="/images/uploads/keittioremontti.webp" alt="Keittiöremontti" class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-musta opacity-0 group-hover:opacity-50 transition-opacity duration-300"></div>
          <img src="/images/uploads/oikea-nuoli.svg" alt="" class="absolute top-s-3-d right-s-3-d w-6 h-6 z-10 group-hover:hidden" />
          <img src="/images/uploads/oikea-nuoli-oranssi.svg" alt="" class="absolute top-s-3-d right-s-3-d w-6 h-6 z-10 hidden group-hover:block" />
          <div class="absolute bottom-0 left-0 right-0 px-s-4-d pt-s-10-d pb-s-4-d bg-gradient-to-t from-musta via-musta/60 to-transparent">
            <h3 class="text-valkoinen text-h4-d ">Keittiöremontti</h3>
            <p class="text-valkoinen text-body-small  leading-5 mt-s-1-d">Keittiö on kodin sydän. Laadukkaasti toteutettu remontti tuo uutta ilmettä ja tekee arjesta sujuvampaa.</p>
          </div>
        </a>

        <a href="/palvelut/kylpyhuone-ja-saunaremontti" class="group relative w-[532px] h-[709px] overflow-hidden">
          <img src="/images/uploads/sauna-ja-kylpyhuoneremontti.webp" alt="Sauna- ja kylpyhuoneremontti" class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-musta opacity-0 group-hover:opacity-50 transition-opacity duration-300"></div>
          <img src="/images/uploads/oikea-nuoli.svg" alt="" class="absolute top-s-3-d right-s-3-d w-6 h-6 z-10 group-hover:hidden" />
          <img src="/images/uploads/oikea-nuoli-oranssi.svg" alt="" class="absolute top-s-3-d right-s-3-d w-6 h-6 z-10 hidden group-hover:block" />
          <div class="absolute bottom-0 left-0 right-0 px-s-4-d pt-s-10-d pb-s-4-d bg-gradient-to-t from-musta via-musta/60 to-transparent">
            <h3 class="text-valkoinen text-h4-d ">Sauna- ja kylpyhuoneremontti</h3>
            <p class="text-valkoinen text-body-small  leading-5 mt-s-1-d">Kylpyhuone- ja saunaremontti turvallisesti ja ammattitaidolla – kestävä ja toimiva lopputulos.</p>
          </div>
        </a>

      </div>

      <!-- Rivi 3: Julkisivuremontti + Uudisrakentaminen -->
      <div class="flex items-start gap-s-3-d">

        <a href="/palvelut/julkisivuremontit" class="group relative w-[532px] h-[709px] overflow-hidden">
          <img src="/images/uploads/julkisivuremontti.webp" alt="Julkisivuremontti" class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-musta opacity-0 group-hover:opacity-50 transition-opacity duration-300"></div>
          <img src="/images/uploads/oikea-nuoli.svg" alt="" class="absolute top-s-3-d right-s-3-d w-6 h-6 z-10 group-hover:hidden" />
          <img src="/images/uploads/oikea-nuoli-oranssi.svg" alt="" class="absolute top-s-3-d right-s-3-d w-6 h-6 z-10 hidden group-hover:block" />
          <div class="absolute bottom-0 left-0 right-0 px-s-4-d pt-s-10-d pb-s-4-d bg-gradient-to-t from-musta via-musta/60 to-transparent">
            <h3 class="text-valkoinen text-h4-d ">Julkisivuremontti</h3>
            <p class="text-valkoinen text-body-small  leading-5 mt-s-1-d">Toteutamme laadukkaat julkisivuremontit omakotitaloihin, taloyhtiöihin ja liikekiinteistöihin.</p>
          </div>
        </a>

        <a href="/palvelut/uudisrakentaminen" class="group relative w-[532px] h-[709px] overflow-hidden">
          <img src="/images/uploads/uudisrakentaminen.webp" alt="Uudisrakentaminen" class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-musta opacity-0 group-hover:opacity-50 transition-opacity duration-300"></div>
          <img src="/images/uploads/oikea-nuoli.svg" alt="" class="absolute top-s-3-d right-s-3-d w-6 h-6 z-10 group-hover:hidden" />
          <img src="/images/uploads/oikea-nuoli-oranssi.svg" alt="" class="absolute top-s-3-d right-s-3-d w-6 h-6 z-10 hidden group-hover:block" />
          <div class="absolute bottom-0 left-0 right-0 px-s-4-d pt-s-10-d pb-s-4-d bg-gradient-to-t from-musta via-musta/60 to-transparent">
            <h3 class="text-valkoinen text-h4-d ">Uudisrakentaminen</h3>
            <p class="text-valkoinen text-body-small  leading-5 mt-s-1-d">Uudisrakentaminen laadukkaasti ja luotettavasti – suunnittelusta valmiiseen rakennukseen.</p>
          </div>
        </a>

      </div>

    </div>

    <!-- Mobiili -->
    <div class="flex lg:hidden flex-col gap-s-5-m px-s-4-m py-s-10-m">

      <!-- Header: ei buttonia -->
      <div class="flex flex-col gap-s-3-m">
        <div class="inline-flex items-center gap-1.5">
          <span class="text-musta text-body-medium leading-5">Palvelut</span>
          <div class="w-16 h-px bg-musta"></div>
        </div>
        <h2 class="text-musta text-h2-m ">Remonttipalvelut moneen tarpeeseen</h2>
        <p class="text-musta text-body-normal  leading-6">
          Meiltä saat laajat remonttipalvelut, jotka kattavat kaiken kodin ja kiinteistöjen kunnostamisesta uudisrakentamiseen.
        </p>
      </div>

      <!-- Kortit -->
      <a href="/palvelut/huoneistoremontit" class="group relative block aspect-[3/4] overflow-hidden">
        <img src="/images/uploads/huoneistoremontti-mobiili.webp" alt="Huoneistoremontti" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-musta opacity-0 group-hover:opacity-50 transition-opacity duration-300"></div>
        <img src="/images/uploads/oikea-nuoli.svg" alt="" class="absolute top-s-3-m right-s-3-m w-5 h-5 z-10 group-hover:hidden" />
        <img src="/images/uploads/oikea-nuoli-oranssi.svg" alt="" class="absolute top-s-3-m right-s-3-m w-5 h-5 z-10 hidden group-hover:block" />
        <div class="absolute bottom-0 left-0 right-0 px-s-4-m py-s-4-m bg-gradient-to-t from-musta to-transparent">
          <h3 class="text-valkoinen text-h4-m ">Huoneistoremontti</h3>
          <p class="text-valkoinen text-body-small  leading-5 mt-s-1-m">Tarjoamme remonttipalvelut pienistä pintätöistä laajoihin kokonaisuuksiin – aina huolellisesti suunniteltuna toteutukseen.</p>
        </div>
      </a>

      <a href="/palvelut/keittioremontit" class="group relative block aspect-[3/4] overflow-hidden">
        <img src="/images/uploads/keittioremontti-mobiili.webp" alt="Keittiöremontti" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-musta opacity-0 group-hover:opacity-50 transition-opacity duration-300"></div>
        <img src="/images/uploads/oikea-nuoli.svg" alt="" class="absolute top-s-3-m right-s-3-m w-5 h-5 z-10 group-hover:hidden" />
        <img src="/images/uploads/oikea-nuoli-oranssi.svg" alt="" class="absolute top-s-3-m right-s-3-m w-5 h-5 z-10 hidden group-hover:block" />
        <div class="absolute bottom-0 left-0 right-0 px-s-4-m py-s-4-m bg-gradient-to-t from-musta to-transparent">
          <h3 class="text-valkoinen text-h4-m ">Keittiöremontti</h3>
          <p class="text-valkoinen text-body-small  leading-5 mt-s-1-m">Keittiö on kodin sydän. Laadukkaasti toteutettu remontti tuo uutta ilmettä ja tekee arjesta sujuvampaa.</p>
        </div>
      </a>

      <a href="/palvelut/kylpyhuone-ja-saunaremontti" class="group relative block aspect-[3/4] overflow-hidden">
        <img src="/images/uploads/sauna-ja-kylpyhuoneremontti-mobiili.webp" alt="Sauna- ja kylpyhuoneremontti" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-musta opacity-0 group-hover:opacity-50 transition-opacity duration-300"></div>
        <img src="/images/uploads/oikea-nuoli.svg" alt="" class="absolute top-s-3-m right-s-3-m w-5 h-5 z-10 group-hover:hidden" />
        <img src="/images/uploads/oikea-nuoli-oranssi.svg" alt="" class="absolute top-s-3-m right-s-3-m w-5 h-5 z-10 hidden group-hover:block" />
        <div class="absolute bottom-0 left-0 right-0 px-s-4-m py-s-4-m bg-gradient-to-t from-musta to-transparent">
          <h3 class="text-valkoinen text-h4-m ">Sauna- ja kylpyhuoneremontti</h3>
          <p class="text-valkoinen text-body-small  leading-5 mt-s-1-m">Kylpyhuone- ja saunaremontti turvallisesti ja ammattitaidolla – kestävä ja toimiva lopputulos.</p>
        </div>
      </a>

      <a href="/palvelut/julkisivuremontit" class="group relative block aspect-[3/4] overflow-hidden">
        <img src="/images/uploads/julkisivuremontti-mobiili.webp" alt="Julkisivuremontti" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-musta opacity-0 group-hover:opacity-50 transition-opacity duration-300"></div>
        <img src="/images/uploads/oikea-nuoli.svg" alt="" class="absolute top-s-3-m right-s-3-m w-5 h-5 z-10 group-hover:hidden" />
        <img src="/images/uploads/oikea-nuoli-oranssi.svg" alt="" class="absolute top-s-3-m right-s-3-m w-5 h-5 z-10 hidden group-hover:block" />
        <div class="absolute bottom-0 left-0 right-0 px-s-4-m py-s-4-m bg-gradient-to-t from-musta to-transparent">
          <h3 class="text-valkoinen text-h4-m ">Julkisivuremontti</h3>
          <p class="text-valkoinen text-body-small  leading-5 mt-s-1-m">Toteutamme laadukkaat julkisivuremontit omakotitaloihin, taloyhtiöihin ja liiketiinteistöihin.</p>
        </div>
      </a>

      <a href="/palvelut/uudisrakentaminen" class="group relative block aspect-[3/4] overflow-hidden">
        <img src="/images/uploads/uudisrakentaminen-mobiili.webp" alt="Uudisrakentaminen" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-musta opacity-0 group-hover:opacity-50 transition-opacity duration-300"></div>
        <img src="/images/uploads/oikea-nuoli.svg" alt="" class="absolute top-s-3-m right-s-3-m w-5 h-5 z-10 group-hover:hidden" />
        <img src="/images/uploads/oikea-nuoli-oranssi.svg" alt="" class="absolute top-s-3-m right-s-3-m w-5 h-5 z-10 hidden group-hover:block" />
        <div class="absolute bottom-0 left-0 right-0 px-s-4-m py-s-4-m bg-gradient-to-t from-musta to-transparent">
          <h3 class="text-valkoinen text-h4-m ">Uudisrakentaminen</h3>
          <p class="text-valkoinen text-body-small  leading-5 mt-s-1-m">Uudisrakentaminen laadukkaasti ja luotettavasti – suunnittelusta valmiiseen rakennukseen.</p>
        </div>
      </a>

    </div>

  </section>

    <!-- Remontti vai uudistus – desktop -->
  <section class="hidden lg:block relative lg:h-[700px]">

    <!-- Taustakuva -->
    <img
      src="/images/uploads/remontti-vai-uudistus.webp"
      alt="J&T Rakennuspalvelu – miksi valita meidät"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-musta opacity-40"></div>

    <!-- Sisältö: kortti bottom-right -->
    <div class="relative h-full flex flex-col justify-end items-end">

      <!-- Kortti -->
      <div class="relative w-[57%] bg-harmaa/80 px-s-7-d py-s-6-d flex flex-col gap-s-3-d">

        <!-- Tagline -->
        <div class="inline-flex items-center gap-1.5">
          <span class="text-musta text-body-large leading-7">Remontit, joihin voit luottaa</span>
          <div class="w-9 h-px bg-musta"></div>
        </div>

        <h2 class="text-musta text-h2-d  max-w-2xl">Kaipaatko remonttia tai uudistusta?</h2>

        <p class="text-musta text-body-normal  leading-6 max-w-2xl mb-s-3-d">
          Olipa kyse keittiöstä, kylpyhuoneesta, saunasta, julkisivusta tai uudisrakentamisesta, hoidamme kaiken projektin suunnittelusta valmiiseen lopputulokseen – 
          ammattitaidolla, luotettavasti ja tarpeidesi mukaan. Ota yhteyttä, niin suunnitellaan ja toteutetaan yhdessä juuri sinun kaipaamasi remontti tai uudistus.
        </p>
    
        <a href="/meista" class="self-start px-s-3-d py-3 bg-oranssi hover:bg-hover-oranssi shadow-[0px_4px_4px_0px_rgba(0,0,0,0.25)] flex justify-center items-center text-black text-body-medium font-normal">
          Ota yhteyttä
        </a>
      </div>
    </div>
  </section>

  <!-- Remontti vai uudistus – mobiili -->
  <section class="flex lg:hidden relative min-h-[600px]">

    <!-- Taustakuva koko section -->
    <img
      src="/images/uploads/remontti-vai-uudistus-mobiili.webp"
      alt="J&T Rakennuspalvelu – miksi valita meidät"
      class="absolute inset-0 w-full h-full object-cover object-bottom"
    />

    <!-- Tekstilaatikko kuvan päällä, alhaalla -->
    <div class="relative mt-auto ml-4 bg-harmaa/80 flex flex-col gap-s-5-m px-s-4-m pt-s-6-m pb-s-8-m">

      <!-- Tagline -->
      <div class="inline-flex items-center gap-1.5">
        <span class="text-musta text-body-medium leading-5">Remontit, joihin voit luottaa</span>
        <div class="w-9 h-px bg-musta"></div>
      </div>

      <h2 class="text-musta text-h2-m ">Kaipaatko remonttia tai uudistusta?</h2>

      <p class="text-musta text-body-normal  leading-6">
        Olipa kyse keittiöstä, kylpyhuoneesta, saunasta, julkisivusta tai uudisrakentamisesta, hoidamme kaiken 
        projektin suunnittelusta valmiiseen lopputulokseen – ammattitaidolla, luotettavasti ja tarpeidesi mukaan. 
        Ota yhteyttä, niin suunnitellaan ja toteutetaan yhdessä juuri sinun kaipaamasi remontti tai uudistus.
      </p>

      <a href="/yhteystiedot" class="self-start px-s-3-d py-3 bg-oranssi shadow-[0px_4px_4px_0px_rgba(0,0,0,0.25)] flex justify-center items-center text-black text-body-medium font-normal">
        Ota yhteyttä
      </a>

    </div>
  </section>

</Layout>
