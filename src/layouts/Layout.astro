---
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/700.css';
import CookieBanner from "../components/CookieBanner.astro";
import ibmPlexSans400Url from '@fontsource/ibm-plex-sans/files/ibm-plex-sans-latin-400-normal.woff2?url';
import ibmPlexSans700Url from '@fontsource/ibm-plex-sans/files/ibm-plex-sans-latin-700-normal.woff2?url';

export interface Props {
  title: string;
  description?: string;
  hasHero?: boolean;
  heroImage?: string;
  heroImageMq?: string;
}

const {
  title = "J&T Rakennuspalvelu Oy",
  description = "J&T Rakennuspalvelu Oy – traktorien ja maatalouskoneiden huolto, varaosat ja myymälä.",
  hasHero = false,
  heroImage,
  heroImageMq = "(min-width: 768px)",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="fi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={`${title} | J&T Rakennuspalvelu Oy`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fi_FI" />
    <title>{title} | J&T Rakennuspalvelu Oy</title>

    <link rel="preload" as="font" type="font/woff2" href={ibmPlexSans400Url} crossorigin="anonymous" />
    <link rel="preload" as="font" type="font/woff2" href={ibmPlexSans700Url} crossorigin="anonymous" />

    {heroImage && (
      <link rel="preload" as="image" href={heroImage} fetchpriority="high" media={heroImageMq} />
    )}
  </head>
  <body class="bg-harmaa text-valkoinen min-h-screen flex flex-col font-body">

    <header id="site-header" class="bg-musta sticky top-0 z-40 transition-transform duration-300">
      <div class="max-w-8xl mx-auto px-s-4-m md:px-[64px] py-4 md:py-s-3-d">
        <nav class="relative flex justify-between items-center">

          <!-- Mobile: phone button (left) -->
          <a href="tel:+358400603295" class="xl:hidden bg-oranssi p-[10px] flex items-center justify-center" aria-label="Soita">
            <img src="/images/uploads/puhelin.svg" alt="" class="w-6 h-6" aria-hidden="true" />
          </a>

          <!-- Mobile: logo (centered, absolute) -->
          <a href="/" class="xl:hidden absolute left-1/2 -translate-x-1/2">
            <img src="/images/uploads/logo.webp" alt="J&T Rakennuspalvelu Turku logo" class="h-8 w-auto">
          </a>

          <!-- Desktop: logo (left) -->
          <a href="/" class="hidden xl:flex items-center font-heading font-bold text-xl text-gray-900 hover:text-oranssi transition-colors">
            <img src="/images/uploads/logo.webp" alt="J&T Rakennuspalvelu Turku logo" class="h-12 w-auto">
          </a>

          <!-- Desktop nav -->
          <div class="hidden xl:flex xl:items-center xl:gap-s-6-d h-full ">

            <!-- Palvelut -->
            <div class="relative group h-full flex items-center">
              <a href="/palvelut" class="flex items-center gap-1 text-base font-medium py-4 transition-colors hover:text-oranssi">
                Palvelut
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19 9-7 7-7-7" />
                </svg>
              </a>
              <div class="absolute left-1/2 -translate-x-1/2 top-full hidden group-hover:block z-50 w-52">
                <div class="bg-valkoinen text-musta shadow-lg">
                  <a href="/palvelut/huoneistoremontit" class="block px-4 py-3 text-base hover:text-oranssi transition-colors">Huoneistoremontti</a>
                  <a href="/palvelut/keittioremontit" class="block px-4 py-3 text-base hover:text-oranssi transition-colors">Keittiöremontti</a>
                  <a href="/palvelut/kylpyhuone-ja-saunaremontti" class="block px-4 py-3 text-base hover:text-oranssi transition-colors">Sauna- ja kylpyhuoneremontti</a>
                  <a href="/palvelut/julkisivuremontit" class="block px-4 py-3 text-base hover:text-oranssi transition-colors">Julkisivuremontti</a>
                  <a href="/palvelut/uudisrakentaminen" class="block px-4 py-3 text-base hover:text-oranssi transition-colors">Uudisrakentaminen</a>
                </div>
              </div>
            </div>
            <a href="/yritys" class="text-base font-medium py-4 hover:text-oranssi transition-colors">Yritys</a>
            <a href="/kuvagalleria" class="text-base font-medium py-4 hover:text-oranssi transition-colors">Galleria</a>
            <a href="/yhteystiedot" class="text-base font-medium py-4 hover:text-oranssi transition-colors">Yhteystiedot</a>
            <a href="tel:+358400603295" class="group flex items-center gap-2 bg-oranssi text-black font-medium px-s-2-d py-[12px] hover:bg-valkoinen transition-all">
              <img src="/images/uploads/puhelin.svg" alt="Puhelimen ikoni" class="w-5 h-5 transition-transform duration-300 group-hover:rotate-[-6deg]" aria-hidden="true" />
              0400 603 295
            </a>
          </div>

          <!-- Mobile hamburger -->
          <div class="xl:hidden">
            <button id="menu-toggle" class="p-2" aria-label="Avaa valikko">
              <div class="w-9 h-7 flex flex-col justify-between">
                <span class="w-1/2 h-[3px] bg-valkoinen self-start"></span>
                <span class="w-full h-[3px] bg-valkoinen"></span>
                <span class="w-1/2 h-[3px] bg-valkoinen self-end"></span>
              </div>
            </button>
          </div>
        </nav>
      </div>
    </header>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden fixed inset-0 z-[100] bg-white overflow-y-auto">
      <div class="flex flex-col px-s-6-m pt-s-6-m min-h-screen">
        <div class="flex justify-end mb-8">
          <button id="close-menu" aria-label="Sulje valikko" class="relative w-8 h-8">
            <span class="absolute top-1/2 left-1/2 w-7 h-0.5 bg-gray-900 origin-center rotate-45 -translate-x-1/2 -translate-y-1/2"></span>
            <span class="absolute top-1/2 left-1/2 w-7 h-0.5 bg-gray-900 origin-center -rotate-45 -translate-x-1/2 -translate-y-1/2"></span>
          </button>
        </div>

        <nav class="flex flex-col gap-6">

          <div class="flex flex-col gap-2">
            <button data-mobile-toggle="palvelut" class="flex items-center gap-2 font-heading text-3xl text-gray-900 text-left">
              Palvelut
              <svg data-arrow="palvelut" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5 transition-transform duration-200">
                <path stroke-linecap="round" stroke-linejoin="round" d="m19 9-7 7-7-7" />
              </svg>
            </button>
            <div id="sub-palvelut" class="hidden flex-col gap-3 pl-4">
              <a href="/palvelut" class="text-gray-900 text-2xl">Kaikki palvelut</a>
              <a href="/palvelut/huoneistoremontit" class="text-gray-900 text-2xl">Huoneistoremontti</a>
              <a href="/palvelut/keittioremontit" class="text-gray-900 text-2xl">Keittiöremontti</a>
              <a href="/palvelut/kylpyhuone-ja-saunaremontti" class="text-gray-900 text-2xl">Sauna- ja kylpyhuoneremontti</a>
              <a href="/palvelut/julkisivuremontit" class="text-gray-900 text-2xl">Julkisivuremontti</a>
              <a href="/palvelut/uudisrakentaminen" class="text-gray-900 text-2xl">Uudisrakentaminen</a>
            </div>
          </div>
          <a href="/yritys" class="font-heading text-3xl text-gray-900">Yritys</a>
          <a href="/kuvagalleria" class="font-heading text-3xl text-gray-900">Galleria</a>
          <a href="/yhteystiedot" class="font-heading text-3xl text-gray-900">Yhteystiedot</a>
        </nav>
      </div>
    </div>

    <main class={`flex-grow${hasHero ? '' : ' pt-8'}`}>
      <slot />
    </main>

    <footer class="bg-musta text-valkoinen">
      <div class="max-w-8xl mx-auto px-s-4-m xl:px-s-6-d py-s-10-d">
        <div class="flex flex-col gap-10 xl:flex-row xl:gap-0">

          <div class="flex flex-col gap-6">
            <a href="/">
              <img src="/images/uploads/logo.webp" alt="J&T Rakennuspalvelu Oy logo" class="h-12 w-auto" />
            </a>
            <img src="/images/uploads/luotettava-kumppani.webp" alt="Olen Luotettava Kumppani" class="hidden xl:block w-28 h-auto" />
          </div>

          <div class="xl:ml-[285px]">
            <h3 class="font-heading font-bold text-base mb-4">Sivut</h3>
            <nav class="flex flex-col gap-2 text-base text-valkoinen">
              <a href="/palvelut" class="hover:text-oranssi transition-colors">Palvelut</a>
              <a href="/yritys" class="hover:text-oranssi transition-colors">Yritys</a>
              <a href="/kuvagalleria" class="hover:text-oranssi transition-colors">Galleria</a>
              <a href="/yhteystiedot" class="hover:text-oranssi transition-colors">Yhteystiedot</a>
            </nav>
          </div>

          <div class="xl:ml-[285px]">
            <h3 class="font-heading font-bold text-base mb-4">Yhteystiedot</h3>
            <address class="not-italic text-base text-valkoinen flex flex-col gap-2">
              <span>J&amp;T Rakennuspalvelu Oy</span>
              <a href="tel:+358207750890" class="hover:text-valkoinen transition-colors">puh. 0207 750 890</a>
              <span>Mäntysaarenkuja 21</span>
              <span>21330 Paattinen</span>
            </address>
          </div>

          <img src="/images/uploads/luotettava-kumppani.webp" alt="Olen Luotettava Kumppani" class="xl:hidden w-28 h-auto" />

        </div>
      </div>
    </footer>

    <CookieBanner />

    <script>
      const menuToggle = document.getElementById("menu-toggle");
      const closeMenuBtn = document.getElementById("close-menu");
      const mobileMenu = document.getElementById("mobile-menu");

      menuToggle?.addEventListener("click", () => {
        mobileMenu?.classList.remove("hidden");
        document.body.style.overflow = "hidden";
      });
      closeMenuBtn?.addEventListener("click", () => {
        mobileMenu?.classList.add("hidden");
        document.body.style.overflow = "";
      });
      mobileMenu?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          mobileMenu?.classList.add("hidden");
          document.body.style.overflow = "";
        });
      });

      document.querySelectorAll("[data-mobile-toggle]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const key = btn.getAttribute("data-mobile-toggle");
          const submenu = document.getElementById(`sub-${key}`);
          const arrow = document.querySelector(`[data-arrow="${key}"]`);
          const isOpen = submenu && !submenu.classList.contains("hidden");
          submenu?.classList.toggle("hidden", !!isOpen);
          submenu?.classList.toggle("flex", !isOpen);
          arrow?.classList.toggle("rotate-180", !isOpen);
        });
      });

      // Hide header on scroll down, show on scroll up
      const header = document.getElementById("site-header");
      let lastScrollY = window.scrollY;

      window.addEventListener("scroll", () => {
        const currentScrollY = window.scrollY;
        if (!header) { lastScrollY = currentScrollY; return; }

        if (currentScrollY > lastScrollY && currentScrollY > 80) {
          // Scrolling down: reset any inline override so CSS transition applies
          header.style.transitionDuration = "";
          header.classList.add("-translate-y-full");
        } else if (currentScrollY < lastScrollY) {
          // Scrolling up: on mobile show instantly, on desktop keep transition
          if (window.innerWidth < 1280) {
            header.style.transitionDuration = "600ms";
            header.classList.remove("-translate-y-full");
          } else {
            header.classList.remove("-translate-y-full");
          }
        }
        lastScrollY = currentScrollY;
      }, { passive: true });
    </script>
  </body>
</html>
